<!--pages/patients/patients.wxml-->
<view class="page">
  <!-- 顶部渐变信息栏 -->
  <view class="hero">
    <view class="hero-inner">
      <view class="hero-user">
        <view class="hero-avatar">{{currentUser.name[0] || 'N'}}</view>
        <view class="hero-info">
          <view class="hero-row">
            <text class="hero-name">{{currentUser.name}}</text>
            <text class="hero-badge">{{currentRoleName}}</text>
          </view>
          <text class="hero-sub">{{currentUser.phone}}</text>
        </view>
        <view class="hero-right">
          <text class="hero-greeting">{{greeting}}</text>
          <text class="hero-date">{{todayStr}}</text>
        </view>
      </view>
      <!-- 统计数字 -->
      <view class="hero-stats" wx:if="{{patients.length > 0}}">
        <view class="hs-item {{activeFilter === 'all' ? 'hs-active' : ''}}" bindtap="filterPatients" data-filter="all" style="position: relative; left: 2rpx; top: 0rpx">
          <text class="hs-num">{{occupiedCount}}</text>
          <text class="hs-label">在院</text>
        </view>
        <view class="hs-divider"></view>
        <view class="hs-item {{activeFilter === 'male' ? 'hs-active' : ''}}" bindtap="filterPatients" data-filter="male">
          <text class="hs-num blue">{{maleCount}}</text>
          <text class="hs-label">男</text>
        </view>
        <view class="hs-divider"></view>
        <view class="hs-item {{activeFilter === 'female' ? 'hs-active' : ''}}" bindtap="filterPatients" data-filter="female">
          <text class="hs-num pink">{{femaleCount}}</text>
          <text class="hs-label">女</text>
        </view>
        <view class="hs-divider" wx:if="{{emptyBedCount > 0}}"></view>
        <view class="hs-item {{activeFilter === 'empty' ? 'hs-active' : ''}}" wx:if="{{emptyBedCount > 0}}" bindtap="filterPatients" data-filter="empty">
          <text class="hs-num gray">{{emptyBedCount}}</text>
          <text class="hs-label">空床</text>
        </view>
        <view class="hs-divider" wx:if="{{movedCount > 0}}"></view>
        <view class="hs-item" wx:if="{{movedCount > 0}}" bindtap="viewMovedPatients">
          <text class="hs-num orange">{{movedCount}}</text>
          <text class="hs-label">出院/转科</text>
        </view>
        <view class="hs-divider" wx:if="{{canManage}}"></view>
        <view class="hs-item" wx:if="{{canManage}}" bindtap="goToApply">
          <text class="hs-num {{pendingCount > 0 ? 'red' : ''}}">{{pendingCount}}</text>
          <text class="hs-label">审批</text>
          <view class="hs-dot" wx:if="{{pendingCount > 0}}"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 搜索 + 操作栏 -->
  <view class="toolbar" wx:if="{{patients.length > 0}}">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索姓名 / 床位 / 诊断" value="{{searchKey}}" bindinput="onSearch" confirm-type="search" />
      <text class="search-clear" wx:if="{{searchKey}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 患者五列网格 -->
  <view class="grid" wx:if="{{displayPatients.length > 0}}">
    <block wx:for="{{displayPatients}}" wx:key="id">
    <!-- 在院患者卡片 -->
    <view class="tile {{item.id === currentPatientId ? 'tile-active' : ''}} {{item.gender === 1 ? 'tile-male' : 'tile-female'}}"
          wx:if="{{!item._isEmpty}}"
          bindtap="selectPatient" data-id="{{item.id}}"
          bindlongpress="{{canManage ? 'showPatientMenu' : ''}}" data-id="{{item.id}}" data-name="{{item.name}}">
      <view class="tile-stripe"></view>
      <view class="tile-avatar {{item.gender === 1 ? 'av-male' : 'av-female'}}">
        <text>{{item.bedNo}}床</text>
      </view>
      <text class="tile-name">{{item.name}} {{item.gender === 1 ? '♂' : '♀'}}</text>
      <text class="tile-info">{{item.age}}岁</text>
      <view class="tile-check" wx:if="{{item.id === currentPatientId}}"></view>
    </view>
    <!-- 空床位卡片（原位保留） -->
    <view class="tile tile-empty"
          wx:elif="{{!searchKey}}"
          bindlongpress="{{canManage ? 'assignToEmptyBed' : ''}}" data-bed="{{item.bedNo}}">
      <view class="tile-stripe tile-stripe-empty"></view>
      <view class="tile-avatar av-empty">
        <text>{{item.bedNo}}床</text>
      </view>
      <text class="tile-name tile-name-empty">空床位</text>
      <text class="tile-info tile-info-empty">待分配</text>
    </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{patients.length === 0 && !searchKey}}">
    <view class="empty-box">
      <text class="empty-title">暂无在院患者</text>
      <text class="empty-desc">点击下方按钮添加第一位患者</text>
    </view>
  </view>
  <view class="empty" wx:if="{{patients.length === 0 && searchKey}}">
    <view class="empty-box">
      <text class="empty-title">未找到匹配患者</text>
      <text class="empty-desc">试试其他关键词</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{patients.length > 0}}">
    <view class="bottom-btn add" bindtap="addPatient" wx:if="{{canManage}}">
      <text class="bottom-btn-icon">+</text>
      <text class="bottom-btn-text">添加患者</text>
    </view>
    <view class="bottom-btn" bindtap="viewMovedPatients" wx:if="{{canManage && movedCount > 0}}">
      <text class="bottom-btn-text">出院记录</text>
    </view>
    <view class="bottom-btn" bindtap="goToNurseManage" wx:if="{{canManage}}">
      <text class="bottom-btn-text">人员管理</text>
    </view>
  </view>
</view>

<!-- 操作菜单 -->
<view class="sheet-mask" wx:if="{{showMenu}}" bindtap="hideMenu">
  <view class="sheet" catchtap="noop">
    <view class="sheet-head">
      <text class="sheet-name">{{menuPatientName}}</text>
      <text class="sheet-close" bindtap="hideMenu">✕</text>
    </view>
    <view class="sheet-list">
      <view class="sheet-item" bindtap="viewPatientDetail"><text>查看详情</text></view>
      <view class="sheet-item" bindtap="viewPatientRecords"><text>健康趋势</text></view>
      <view class="sheet-item" bindtap="editPatientFromMenu" wx:if="{{canManage}}"><text>编辑信息</text></view>
      <view class="sheet-item sheet-danger" bindtap="moveOutFromMenu" wx:if="{{canManage}}"><text>出院 / 转科</text></view>
    </view>
  </view>
</view>

<!-- 出院/转科弹窗 -->
<view class="modal-mask" wx:if="{{showMoveModal}}" bindtap="closeMoveModal">
  <view class="modal" catchtap="noop">
    <view class="modal-head">
      <text>出院 / 转科</text>
      <text class="modal-x" bindtap="closeMoveModal">✕</text>
    </view>
    <view class="modal-body">
      <text class="modal-patient">{{moveModalPatientName}}</text>
      <text class="modal-label">操作类型</text>
      <view class="modal-opts">
        <view class="opt {{moveReason === 'discharge' ? 'opt-on' : ''}}" bindtap="selectReason" data-reason="discharge"><text>出院</text></view>
        <view class="opt {{moveReason === 'transfer' ? 'opt-on' : ''}}" bindtap="selectReason" data-reason="transfer"><text>转科</text></view>
      </view>
      <text class="modal-label">备注（选填）</text>
      <textarea class="modal-ta" placeholder="如转至XX科、出院原因等" value="{{moveNote}}" bindinput="onNoteInput" maxlength="100"></textarea>
    </view>
    <view class="modal-foot">
      <view class="modal-btn cancel" bindtap="closeMoveModal"><text>取消</text></view>
      <view class="modal-btn {{moveReason ? 'ok' : 'disabled'}}" bindtap="confirmMoveOut"><text>确认</text></view>
    </view>
  </view>
</view>

<!-- 出院记录弹窗 -->
<view class="modal-mask" wx:if="{{showMovedList}}" bindtap="closeMovedList">
  <view class="modal modal-lg" catchtap="noop">
    <view class="modal-head">
      <text>出院/转科记录（{{movedPatientsFull.length}}人）</text>
      <text class="modal-x" bindtap="closeMovedList">✕</text>
    </view>
    <scroll-view class="modal-scroll" scroll-y>
      <view class="moved-list" wx:if="{{movedPatientsFull.length > 0}}">
        <view class="moved-item" wx:for="{{movedPatientsFull}}" wx:key="id">
          <view class="moved-row">
            <view class="moved-avatar {{item.gender === 1 ? 'male' : 'female'}}">{{item.name[0]}}</view>
            <view class="moved-info">
              <text class="moved-name">{{item.name}}</text>
              <text class="moved-desc">{{item.bedNo ? item.bedNo + '床 · ' : ''}}{{item.age}}岁 · {{item.gender === 1 ? '男' : '女'}}</text>
            </view>
            <text class="moved-tag {{item.moveReason === 'discharge' ? 't-discharge' : 't-transfer'}}">{{item.moveReason === 'discharge' ? '出院' : '转科'}}</text>
          </view>
          <view class="moved-note" wx:if="{{item.moveNote}}"><text>备注：{{item.moveNote}}</text></view>
          <view class="moved-time"><text>{{item.movedOutTime}}</text></view>
          <view class="moved-restore" wx:if="{{canManage}}" bindtap="restorePatient" data-id="{{item.id}}"><text>恢复在院</text></view>
        </view>
      </view>
      <view class="empty-modal" wx:else><text>暂无记录</text></view>
    </scroll-view>
  </view>
</view>
