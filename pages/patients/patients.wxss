/* pages/patients/patients.wxss */

.page {
  min-height: 100vh;
  background: #F5F6FA;
  padding-bottom: 140rpx;
}

/* ===== 顶部渐变信息栏 ===== */
.hero {
  background: linear-gradient(135deg, #5B7FFF 0%, #8B5CF6 50%, #A78BFA 100%);
  padding: 40rpx 32rpx 36rpx;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -40rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero::before {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -30rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.hero-inner {
  position: relative;
  z-index: 1;
}

.hero-user {
  display: flex;
  align-items: center;
}

.hero-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  backdrop-filter: blur(10px);
}

.hero-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.hero-row {
  display: flex;
  align-items: center;
}

.hero-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 12rpx;
}

.hero-badge {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.2);
  padding: 3rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.hero-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
  margin-top: 4rpx;
  display: block;
}

.hero-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.hero-greeting {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  display: block;
}

.hero-date {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.55);
  display: block;
  margin-top: 2rpx;
}

/* 统计数字 */
.hero-stats {
  display: flex;
  align-items: stretch;
  margin-top: 32rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
  overflow: hidden;
}

.hs-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: background 0.2s;
}

/* 点击反馈效果 */
.hs-item:active {
  background: rgba(255, 255, 255, 0.25);
}

.hs-item.hs-active {
  background: rgba(255, 255, 255, 0.15);
}

/* 除最后一个外，右侧加柔和分隔线 */
.hs-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 50%;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 1rpx;
}

.hs-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  line-height: 1.2;
}

.hs-num.blue { color: #93C5FD; }
.hs-num.pink { color: #F9A8D4; }
.hs-num.orange { color: #FCD34D; }
.hs-num.gray { color: #CBD5E1; }
.hs-num.red { color: #FEE2E2; font-weight: 800; }

.hs-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2rpx;
  display: block;
}

.hs-item {
  position: relative;
}

.hs-dot {
  position: absolute;
  top: -2rpx;
  right: calc(50% - 48rpx);
  width: 14rpx;
  height: 14rpx;
  background: #EF4444;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  animation: pulse-dot 1.5s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.4); opacity: 0.6; }
}

.hs-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* ===== 搜索栏 ===== */
.toolbar {
  padding: 20rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  background: #F5F6FA;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  opacity: 0.4;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 72rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #CCC;
  padding: 10rpx;
  flex-shrink: 0;
}

/* ===== 患者五列立体网格 ===== */
.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 14rpx 24rpx 0;
}

.tile {
  width: 17.2%;
  margin-left: 2%;
  margin-bottom: 16rpx;
  position: relative;
  border-radius: 20rpx;
  padding: 22rpx 4rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow:
    0 2rpx 6rpx rgba(0, 0, 0, 0.06),
    0 6rpx 16rpx rgba(0, 0, 0, 0.06),
    0 10rpx 24rpx rgba(0, 0, 0, 0.04);
  border-bottom: 4rpx solid rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

/* 每行第1个无左边距 */
.tile:nth-child(5n+1) {
  margin-left: 0;
}

/* 男卡渐变 */
.tile-male {
  background: linear-gradient(170deg, #EBF4FE 0%, #D4E8FB 40%, #C8DFEF 100%);
  border-color: rgba(100, 170, 230, 0.1);
  border-bottom-color: rgba(70, 140, 200, 0.2);
}

/* 女卡渐变 */
.tile-female {
  background: linear-gradient(170deg, #FEF0F4 0%, #FBDCE6 40%, #F7D0DE 100%);
  border-color: rgba(230, 120, 160, 0.1);
  border-bottom-color: rgba(210, 100, 140, 0.2);
}

.tile:active {
  transform: scale(0.93) translateY(2rpx);
  box-shadow:
    0 1rpx 2rpx rgba(0, 0, 0, 0.04),
    0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}

/* 选中卡片 */
.tile-active.tile-male {
  background: linear-gradient(170deg, #C5DDFB 0%, #A3C8F0 40%, #8FB8E8 100%);
  box-shadow:
    0 2rpx 8rpx rgba(60, 130, 200, 0.15),
    0 6rpx 18rpx rgba(60, 130, 200, 0.2),
    0 12rpx 28rpx rgba(60, 130, 200, 0.1);
  border-bottom-color: rgba(50, 120, 190, 0.35);
}

.tile-active.tile-female {
  background: linear-gradient(170deg, #FBDFE8 0%, #F5C2D4 40%, #F0B0C6 100%);
  box-shadow:
    0 2rpx 8rpx rgba(200, 80, 130, 0.15),
    0 6rpx 18rpx rgba(200, 80, 130, 0.2),
    0 12rpx 28rpx rgba(200, 80, 130, 0.1);
  border-bottom-color: rgba(190, 70, 120, 0.35);
}

/* 空床位卡片 */
.tile-empty {
  background: linear-gradient(170deg, #F1F5F9 0%, #E8ECF1 40%, #E2E8F0 100%);
  border-color: rgba(148, 163, 184, 0.1);
  border-bottom-color: rgba(148, 163, 184, 0.15);
  border-style: dashed;
  border-width: 2rpx;
}

.tile-empty:active {
  transform: scale(0.93) translateY(2rpx);
  box-shadow:
    0 1rpx 2rpx rgba(0, 0, 0, 0.04),
    0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}

.tile-stripe-empty {
  background: repeating-linear-gradient(90deg, #CBD5E1 0, #CBD5E1 8rpx, transparent 8rpx, transparent 16rpx);
}

.av-empty {
  color: #94A3B8;
  background: linear-gradient(145deg, #F8FAFC, #EFF3F8) !important;
  box-shadow: inset 0 0 0 2rpx dashed #CBD5E1 !important;
}

.tile-name-empty {
  color: #94A3B8 !important;
  font-weight: 600 !important;
  font-size: 22rpx !important;
}

.tile-info-empty {
  color: #CBD5E1 !important;
}

/* 性别色条 */
.tile-stripe {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.tile-male .tile-stripe {
  background: linear-gradient(90deg, #4A9FE5, #2E7EC7, #4A9FE5);
}

.tile-female .tile-stripe {
  background: linear-gradient(90deg, #E87A9E, #D45680, #E87A9E);
}

/* 头像 */
.tile-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  background: #fff;
  box-shadow:
    0 3rpx 8rpx rgba(0, 0, 0, 0.08),
    0 1rpx 3rpx rgba(0, 0, 0, 0.06);
}

.av-male {
  color: #2B7CB8;
  background: linear-gradient(145deg, #fff, #F0F7FD);
}

.av-female {
  color: #B8456A;
  background: linear-gradient(145deg, #fff, #FDF0F4);
}

/* 床位标签 */
.tile-bed {
  font-size: 17rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.55);
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 600;
  margin-bottom: 3rpx;
  backdrop-filter: blur(6px);
}

.tile-male .tile-bed {
  color: #2E6FA0;
}

.tile-female .tile-bed {
  color: #A04060;
}

/* 姓名 */
.tile-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #1A365D;
  margin-bottom: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
  text-align: center;
  text-shadow: 0 1rpx 1rpx rgba(255, 255, 255, 0.6);
}

/* 年龄 */
.tile-info {
  font-size: 17rpx;
  color: rgba(30, 50, 80, 0.45);
  font-weight: 500;
}

/* 选中勾选标记 */
.tile-check {
  position: absolute;
  top: 10rpx;
  right: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.12);
}

.tile-check::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 5rpx;
  width: 5rpx;
  height: 9rpx;
  border: 2rpx solid #3B82F6;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 50;
}

.bottom-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-radius: 14rpx;
  background: #F1F5F9;
}

.bottom-btn.add {
  background: #6366F1;
}

.bottom-btn-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
}

.bottom-btn.add .bottom-btn-text {
  color: #fff;
  font-weight: 600;
}

.bottom-btn-text {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
}

.bottom-btn.home .bottom-btn-text {
  color: #6366F1;
  font-weight: 600;
}

/* ===== 空状态 ===== */
.empty {
  padding: 120rpx 0;
}

.empty-box {
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  color: #94A3B8;
  font-weight: 600;
  display: block;
}

.empty-desc {
  font-size: 24rpx;
  color: #CBD5E1;
  margin-top: 12rpx;
  display: block;
}

/* ===== 操作菜单 ===== */
.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx 20rpx;
}

.sheet-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
}

.sheet-close {
  font-size: 36rpx;
  color: #94A3B8;
  padding: 8rpx;
}

.sheet-list {
  padding: 8rpx 0 20rpx;
}

.sheet-item {
  padding: 28rpx 36rpx;
  font-size: 30rpx;
  color: #334155;
  font-weight: 500;
}

.sheet-danger {
  color: #EF4444;
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  background: #fff;
  border-radius: 28rpx;
  width: 86%;
  max-height: 80vh;
  overflow: hidden;
}

.modal-lg {
  width: 92%;
  max-height: 85vh;
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #F1F5F9;
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
}

.modal-x {
  font-size: 36rpx;
  color: #94A3B8;
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx 36rpx;
}

.modal-patient {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 28rpx;
  text-align: center;
}

.modal-label {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.modal-opts {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.opt {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  font-size: 28rpx;
  color: #64748B;
  font-weight: 500;
}

.opt-on {
  background: #EEF2FF;
  border-color: #6366F1;
  color: #6366F1;
  font-weight: 700;
}

.modal-ta {
  width: 100%;
  height: 120rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #E2E8F0;
}

.modal-foot {
  display: flex;
  border-top: 1rpx solid #F1F5F9;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  color: #94A3B8;
  border-right: 1rpx solid #F1F5F9;
}

.modal-btn.ok {
  color: #6366F1;
}

.modal-btn.disabled {
  color: #CBD5E1;
}

/* ===== 出院记录 ===== */
.modal-scroll {
  height: 60vh;
}

.moved-list {
  padding: 0 28rpx 28rpx;
}

.moved-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F8FAFC;
}

.moved-item:last-child {
  border-bottom: none;
}

.moved-row {
  display: flex;
  align-items: center;
}

.moved-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.moved-avatar.male {
  background: linear-gradient(145deg, #DBEAFE, #BFDBFE);
  color: #2563EB;
}

.moved-avatar.female {
  background: linear-gradient(145deg, #FCE7F3, #FBCFE8);
  color: #DB2777;
}

.moved-info {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.moved-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
}

.moved-desc {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
  margin-top: 4rpx;
}

.moved-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.t-discharge {
  background: #FEF3C7;
  color: #D97706;
}

.t-transfer {
  background: #DBEAFE;
  color: #2563EB;
}

.moved-note {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  padding-left: 72rpx;
}

.moved-time {
  font-size: 20rpx;
  color: #CBD5E1;
  margin-top: 4rpx;
  padding-left: 72rpx;
}

.empty-modal {
  text-align: center;
  padding: 80rpx 0;
  color: #CBD5E1;
  font-size: 28rpx;
}

/* ===== 空床位选择弹窗 ===== */
.modal-hint {
  font-size: 24rpx;
  color: #94A3B8;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.bed-picker-scroll {
  height: 400rpx;
}

.bed-picker-grid {
  display: flex;
  flex-wrap: wrap;
}

.bed-picker-item {
  width: 17.2%;
  margin-left: 2%;
  margin-bottom: 20rpx;
  height: 80rpx;
  background: #F1F5F9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.bed-picker-item:nth-child(5n+1) {
  margin-left: 0;
}

.bed-picker-item.bed-selected {
  background: #6366F1;
  color: #fff;
}

.bed-picker-item:active {
  opacity: 0.7;
}
