/* pages/record/record.wxss */
.page-container {
  padding: 24rpx;
  padding-bottom: 40rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

/* === 顶部区域 === */
.header-section {
  padding: 16rpx 0 24rpx;
}

.patient-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.patient-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.patient-bed {
  font-size: 24rpx;
  color: #4A90D9;
  background: #F0F7FF;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
}

.date-arrow {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #4A90D9;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.date-arrow:active {
  background: #F0F7FF;
}

.date-arrow.disabled {
  color: #DDD;
  pointer-events: none;
}

.date-display {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  min-width: 260rpx;
  justify-content: center;
}

.date-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.date-sub {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.date-arrow-small {
  font-size: 18rpx;
  color: #BBB;
  margin-left: 8rpx;
}

.today-btn {
  text-align: center;
  margin-top: 8rpx;
}

.today-btn text {
  font-size: 24rpx;
  color: #4A90D9;
}

/* === 指标选择 === */
.indicator-section {
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.indicator-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.indicator-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 3rpx solid #E8E8E8;
  transition: all 0.2s;
}

.indicator-item:active {
  transform: scale(0.96);
}

.indicator-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.indicator-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
}

.indicator-unit {
  font-size: 20rpx;
  color: #BBB;
  margin-top: 4rpx;
}

/* === 表单区域 === */
.form-section {
  margin-bottom: 24rpx;
}

.form-card {
  padding: 32rpx;
}

.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-date {
  font-size: 24rpx;
  color: #F5A623;
  background: #FFF8EC;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* === 快捷值 === */
.quick-values {
  margin-bottom: 28rpx;
}

.quick-label {
  font-size: 22rpx;
  color: #AAA;
  margin-bottom: 12rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-item {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.quick-item:active {
  opacity: 0.7;
}

/* === 数值输入 === */
.input-group {
  margin-top: 8rpx;
}

.input-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.input-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.input-range {
  font-size: 22rpx;
  color: #BBB;
}

.input-row {
  display: flex;
  align-items: baseline;
  border-bottom: 2rpx solid #EEE;
  padding-bottom: 16rpx;
}

.main-input {
  flex: 1;
  font-size: 56rpx;
  font-weight: 700;
  height: 80rpx;
}

.input-unit {
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
}

/* === 血压输入 === */
.bp-input-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bp-item {
  flex: 1;
}

.bp-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.bp-input-row {
  display: flex;
  align-items: baseline;
  border-bottom: 2rpx solid #EEE;
  padding-bottom: 12rpx;
}

.bp-input {
  font-size: 44rpx;
  font-weight: 700;
  color: #5B7FFF;
  flex: 1;
}

.bp-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.bp-divider {
  font-size: 48rpx;
  color: #CCC;
  margin: 0 20rpx;
  padding-bottom: 12rpx;
}

.bp-hint {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #F5F8FF;
  border-radius: 12rpx;
  border-left: 6rpx solid #5B7FFF;
}

.hint-text {
  font-size: 22rpx;
  color: #5B7FFF;
  line-height: 1.5;
}

/* === 字段行 === */
.field-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.field-label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.field-value {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.field-arrow {
  font-size: 32rpx;
  color: #CCC;
  margin-left: 8rpx;
}

.field-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 8rpx 0;
}

/* === 补录提示 === */
.backfill-tip {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFF8EC;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #F5A623;
}

.backfill-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.backfill-text {
  font-size: 24rpx;
  color: #F5A623;
}

/* === 提交按钮 === */
.submit-section {
  padding: 20rpx 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* === 未选择提示 === */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #BBB;
}

/* === 当天记录 === */
.day-records {
  margin-top: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4A90D9;
}

.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.record-value {
  font-size: 30rpx;
  font-weight: 600;
}

.record-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.record-delete {
  padding: 12rpx;
}

.delete-icon {
  font-size: 28rpx;
  color: #CCC;
}

/* === 通用卡片 === */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* === 安全区域 === */
.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* === 按钮 === */
.btn-primary {
  background: #4A90D9;
  color: #fff;
  border: none;
}

.btn-primary::after {
  border: none;
}
