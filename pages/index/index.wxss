/* pages/index/index.wxss */
.page-container {
  padding-bottom: 40rpx;
}

/* 顶部区域 */
.header-section {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  padding: 32rpx 32rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 24rpx;
}

/* 日期翻页 */
.date-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.date-arrow {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  font-weight: 300;
}

.date-arrow:active {
  background: rgba(255, 255, 255, 0.3);
}

.date-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  position: relative;
}

.date-week {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.date-str {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.date-today-tag {
  font-size: 18rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* 顶部操作栏 */
.top-actions {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  position: relative;
}

.action-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #fff;
}

.action-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.greeting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.date-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.patient-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.patient-row.no-patient {
  border: 2rpx dashed rgba(255, 255, 255, 0.5);
}

.patient-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #4A90D9;
  margin-right: 20rpx;
}

.empty-avatar {
  font-size: 40rpx;
  color: #4A90D9;
}

.patient-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.patient-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 4rpx;
}

.patient-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.arrow-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 快速统计 */
.quick-stats {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A90D9;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  background: #EEE;
  margin: 0 20rpx;
}

/* 区域标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 24rpx 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4A90D9;
}

/* 健康卡片 */
.health-card {
  margin: 0 24rpx 20rpx;
  padding: 0;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx 12rpx;
}

.card-left {
  display: flex;
  align-items: center;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-right {
  display: flex;
  align-items: center;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.status-normal { background: #E8F5E9; color: #4CAF50; }
.status-warning { background: #FFF3E0; color: #FF9800; }
.status-danger { background: #FFEBEE; color: #F44336; }
.status-empty { background: #F0F0F0; color: #999; }

.chart-link {
  font-size: 24rpx;
  color: #4A90D9;
}

.card-body {
  padding: 0 28rpx 24rpx;
}

.value-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.value-number {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.value-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 进度条 */
.progress-bar {
  margin-bottom: 8rpx;
}

.progress-track {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.range-row {
  margin-top: 8rpx;
}

.range-text {
  font-size: 22rpx;
  color: #BBB;
}

/* 体征网格 */
.vital-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 24rpx;
}

.vital-card {
  padding: 24rpx;
  text-align: center;
}

.vital-header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 12rpx;
}

.vital-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.vital-value {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.vital-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.vital-unit {
  font-size: 20rpx;
  color: #BBB;
  margin-top: 4rpx;
}

.vital-top {
  cursor: pointer;
}

.vital-chart-link {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0F0F0;
  text-align: center;
  font-size: 22rpx;
  color: #4A90D9;
  cursor: pointer;
}

/* 血压双值 */
.bp-value-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.bp-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bp-num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
}

.bp-label {
  font-size: 18rpx;
  color: #BBB;
  margin-top: 2rpx;
}

.bp-sep {
  font-size: 28rpx;
  color: #CCC;
  font-weight: 300;
}

/* 迷你图表 */
.mini-chart {
  padding: 12rpx 0;
}

.chart-bar-group {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 160rpx;
  padding: 0 8rpx;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.chart-bar-wrapper {
  width: 40rpx;
  height: 120rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.chart-bar {
  width: 100%;
  min-height: 4rpx;
  border-radius: 8rpx;
  transition: height 0.3s ease;
}

.chart-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.chart-legend {
  text-align: center;
  padding-top: 8rpx;
}

.legend-text {
  font-size: 24rpx;
  color: #4A90D9;
}

/* 快速记录按钮 */
.quick-actions {
  padding: 20rpx 24rpx;
}

.quick-record-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 添加按钮 */
.add-btn {
  margin-top: 32rpx;
  padding: 20rpx 60rpx;
}

.demo-btn {
  margin-top: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
}

/* 空状态 */
.empty-state {
  margin-top: 80rpx;
}
