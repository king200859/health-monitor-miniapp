/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: #F5F7FA;
  display: flex;
  flex-direction: column;
}

/* 顶部装饰 */
.login-header {
  position: relative;
  height: 520rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(160deg, #4A90D9 0%, #357ABD 40%, #6AABF0 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
  background: #fff;
}

.header-circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: -40rpx;
  right: -30rpx;
}

.header-circle-2 {
  width: 120rpx;
  height: 120rpx;
  bottom: 60rpx;
  left: 40rpx;
}

.header-circle-3 {
  width: 80rpx;
  height: 80rpx;
  top: 80rpx;
  left: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.logo-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
}

.app-logo {
  font-size: 64rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 6rpx;
}

.app-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 10rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.feature-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.tag {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  backdrop-filter: blur(10rpx);
}

.tag text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
}

/* 登录主体 */
.login-body {
  flex: 1;
  padding: 40rpx 36rpx 0;
  display: flex;
  flex-direction: column;
  margin-top: -30rpx;
}

.card-section {
  display: flex;
  flex-direction: column;
}

.section-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
  letter-spacing: 2rpx;
}

/* 授权卡片 */
.auth-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 52rpx 32rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.08);
}

.auth-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.auth-icon {
  font-size: 48rpx;
}

.auth-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.auth-desc {
  font-size: 24rpx;
  color: #AAA;
  margin-bottom: 40rpx;
}

.btn-wechat-auth {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  letter-spacing: 6rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  line-height: 1;
}

.btn-wechat-auth::after {
  border: none;
}

.btn-wechat-auth:active {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.2);
}

.wechat-icon {
  margin-right: 8rpx;
  font-size: 30rpx;
  vertical-align: middle;
}

.auth-hint {
  font-size: 20rpx;
  color: #CCC;
  margin-top: 24rpx;
}

/* 分割线 */
.divider-wrap {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
  gap: 24rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #DDD, transparent);
}

.divider-text {
  font-size: 22rpx;
  color: #CCC;
  letter-spacing: 2rpx;
}

/* 手动输入手机号 */
.phone-input-card.disabled {
  opacity: 0.5;
  background: #F5F5F5;
  box-shadow: none;
}

.disabled-section {
  position: relative;
}

.phone-input-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.08);
  height: 100rpx;
}

.input-prefix {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.input-divider {
  width: 2rpx;
  height: 40rpx;
  background: #E0E0E0;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.phone-input {
  flex: 1;
  font-size: 32rpx;
  height: 100rpx;
  color: #333;
}

.btn-phone-login {
  height: 92rpx;
  line-height: 92rpx;
  margin-top: 24rpx;
  background: #D0DCE8;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  letter-spacing: 4rpx;
  transition: all 0.3s;
}

.btn-phone-login::after {
  border: none;
}

.btn-phone-login.active {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.btn-phone-login[disabled] {
  background: #D0DCE8;
  color: #fff;
}

.btn-phone-login.disabled {
  background: #D0DCE8 !important;
  box-shadow: none !important;
}

.disabled-badge {
  background: #FFF3E0;
  border-radius: 8rpx;
  padding: 8rpx 20rpx;
  margin-bottom: 16rpx;
  display: inline-flex;
  align-self: flex-start;
}

.disabled-badge text {
  font-size: 22rpx;
  color: #F5A623;
  letter-spacing: 1rpx;
}

/* 模拟账号列表 */
.phone-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.phone-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.06);
  transition: all 0.2s;
}

.phone-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 217, 0.1);
}

.phone-item-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.phone-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.phone-item-role {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.phone-item-label {
  font-size: 24rpx;
  color: #AAA;
}

.phone-item-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.phone-item-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 返回链接 */
.back-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  padding: 16rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #4A90D9;
  margin-right: 4rpx;
}

.back-text {
  font-size: 26rpx;
  color: #4A90D9;
  letter-spacing: 2rpx;
}

/* 结果卡片 */
.result-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 36rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.08);
}

.result-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.result-circle-approved {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
}

.result-circle-pending {
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
}

.result-circle-rejected {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
}

.result-circle-unknown {
  background: linear-gradient(135deg, #F5F5F5, #E0E0E0);
}

.result-icon {
  font-size: 64rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #AAA;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 44rpx;
}

.result-pending .result-title {
  color: #F5A623;
}

.result-rejected .result-title {
  color: #F44336;
}

.result-unknown .result-title {
  color: #999;
}

.result-actions {
  width: 100%;
  display: flex;
  justify-content: center;
}

.btn-enter {
  width: 80%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.btn-enter::after {
  border: none;
}

.btn-enter:active {
  transform: scale(0.98);
}

.btn-back {
  width: 80%;
  height: 92rpx;
  line-height: 92rpx;
  background: #F5F7FA;
  color: #666;
  font-size: 30rpx;
  border-radius: 46rpx;
  border: none;
  letter-spacing: 2rpx;
}

.btn-back::after {
  border: none;
}

.btn-back:active {
  background: #EBEEF3;
}

.designer-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* 底部说明 */
.login-footer {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 60rpx;
}

.footer-inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #CCC;
  letter-spacing: 1rpx;
}

.footer-divider {
  font-size: 16rpx;
  color: #DDD;
}
