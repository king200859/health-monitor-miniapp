/* pages/apply/apply.wxss */
.page-container {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
  position: relative;
}

.tab-item.active {
  background: #4A90D9;
  color: #ffffff;
  font-weight: 500;
}

.tab-badge {
  position: absolute;
  top: 4rpx;
  right: 12rpx;
  background: #F44336;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  text-align: center;
}

/* 申请卡片 */
.app-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.app-card {
  padding: 24rpx;
}

.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.app-role-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.tag-caregiver {
  background: #F5A62320;
  color: #E09500;
}

.tag-patient {
  background: #7ED32120;
  color: #5EAE14;
}

.app-status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: #FFF3E0;
  color: #F5A623;
}

.status-approved {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-rejected {
  background: #FFEBEE;
  color: #F44336;
}

/* 申请信息 */
.app-body {
  margin-bottom: 16rpx;
}

.app-info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.app-info-row:last-child {
  border-bottom: none;
}

.app-info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.app-info-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
}

/* 操作按钮 */
.app-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.btn-approve, .btn-reject {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
  border: none;
  line-height: 1.5;
}

.btn-approve {
  background: #4A90D9;
  color: #fff;
}

.btn-approve::after {
  border: none;
}

.btn-reject {
  background: #FFF;
  color: #F44336;
  border: 1rpx solid #F44336;
}

.btn-reject::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
