/* pages/nurse-manage/nurse-manage.wxss */

.page-container {
  padding: 0;
  padding-bottom: 40rpx;
  background: #F5F7FA;
  min-height: 100vh;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #999;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-item.active {
  color: #4A90D9;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #4A90D9;
  border-radius: 3rpx;
}

.tab-badge {
  background: #4A90D9;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

/* 列表区域 */
.list-section {
  padding: 24rpx;
}

/* 管理卡片 */
.manage-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.card-main {
  display: flex;
  align-items: center;
  padding: 28rpx;
}

.card-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-phone {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.card-patients {
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
  display: block;
}

.card-patients.empty {
  color: #CCC;
}

/* 关联患者标签列表 */
.assigned-list {
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
}

.assigned-label {
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
  margin-right: 4rpx;
  margin-top: 6rpx;
}

.assigned-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.assigned-tag {
  font-size: 20rpx;
  color: #4A90D9;
  background: #EBF3FC;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

/* 状态标签 */
.status-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

.status-bound {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-unbound {
  background: #FFF3E0;
  color: #FF9800;
}

.status-pending {
  background: #FFF8E1;
  color: #F5A623;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.card-actions .action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #4A90D9;
}

.card-actions .action-btn.danger {
  color: #F44336;
  border-left: 1rpx solid #F0F0F0;
}

/* 通用 card 样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 24rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC;
}

/* 添加按钮 */
.add-section {
  padding: 20rpx 24rpx;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}
